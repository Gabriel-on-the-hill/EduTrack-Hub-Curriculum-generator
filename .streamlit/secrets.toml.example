# ==========================================================
# EduTrack Curriculum Generator — Streamlit Secrets Template
# ==========================================================
# Copy this to .streamlit/secrets.toml and fill in values.
# On Streamlit Cloud, set these via the Secrets section in
# your app settings (Settings > Secrets).
# ==========================================================

# --- REQUIRED ---

# Access code for the web UI (password gate)
ACCESS_CODE = "your-access-code-here"

# Gemini API key (get free at https://aistudio.google.com)
GOOGLE_API_KEY = "your-gemini-api-key-here"

# AI provider: "gemini" (recommended) or "openrouter"
AI_PROVIDER = "gemini"

# --- DATABASE ---
# PostgreSQL URL for production (Supabase, Neon, etc.)
# If not set, the app falls back to a local SQLite demo database.
# DATABASE_URL = "postgresql://user:pass@host:5432/edutrack"

# --- OPTIONAL: SEARCH UPGRADE ---
# Google Custom Search Engine API (dramatically better search results)
# Without these, the app uses DuckDuckGo (free but limited).
# Get keys at: https://developers.google.com/custom-search/v1/overview
# GOOGLE_CSE_API_KEY = "your-google-cse-api-key"
# GOOGLE_CSE_CX = "your-custom-search-engine-id"

# --- OPTIONAL: OPENROUTER FALLBACK ---
# Only needed if AI_PROVIDER = "openrouter" or as Gemini fallback
# OPENROUTER_API_KEY = "your-openrouter-api-key"
